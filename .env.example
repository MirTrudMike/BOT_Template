# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Telegram bot
# ---------------------------------------------------------------------------
BOT_TOKEN=your_bot_token_here
ADMIN_ID=123456789
BOT_PASSWORD=secret_password

# ---------------------------------------------------------------------------
# PostgreSQL (asyncpg DSN format)
# ---------------------------------------------------------------------------
DB_DSN=postgresql://user:password@localhost:5432/dbname

# Optional individual fields if you prefer to build the DSN in code:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dbname
# DB_USER=user
# DB_PASSWORD=password

# ---------------------------------------------------------------------------
# Redis (FSM storage)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Group / channel blocking (optional)
# ---------------------------------------------------------------------------
# Comma-separated list of group chat IDs that ARE allowed (whitelist).
# If empty, all group updates are blocked.
# ALLOWED_GROUP_IDS=

# ---------------------------------------------------------------------------
# TODO: project-specific — add your own variables below
# ---------------------------------------------------------------------------
# GOOGLE_SHEET_ID=
# SOME_GROUP_ID=
